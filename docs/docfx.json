{
  "metadata": [
    {
      "src": [
        {
          "src": "..\\UniKuroKit\\",
          "files": [
            "com.kurokitten.unikurokit.csproj"
          ]
        },
        {
          "src": "..\\UniKuroKit\\",
          "files": [
            "com.kurokitten.unikurokit.events.csproj"
          ]
        }
      ],
      "globalNamespaceId": "Global",
      "filter": "filterConfig.yml",
      "dest": "api",
      "disableGitFeatures": true
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}",
          "toc.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      },
      {
        "src": "api",
        "files": [
          "*.yml"
        ],
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": []
      }
    ],
    "sitemap": {
      "baseUrl": "https://kurokitten.github.io/UniKuroKit/",
      "changefreq": "weekly",
      "fileOptions": {
        "api/*": {
          "changefreq": "daily"
        }
      },
      "output": "_site",
      "template": [
        "default",
        "modern"
      ],
      "globalMetadata": {
        "_appName": "UniKuroKit",
        "_appTitle": "UniKuroKit",
        "_appFooter": "UniKuroKit is licensed under the MIT License. Copyright (c) 2026 KuroKitten.",
        "_enableSearch": true,
        "pdf": false
      }
    },
    "dest": "../pages"
  }
}